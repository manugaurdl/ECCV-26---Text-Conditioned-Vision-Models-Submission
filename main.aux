\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Text specificity controls feature granularity.} On the PODS benchmark, coarse prompts (supercategory) degrade performance relative to DINOv2 by discarding instance-level cues. Class-level prompts improve over the baseline. Fine-grained descriptive prompts surpass even a supervised fine-tuned DINOv2, confirming that detailed text acts as a precise steering mechanism.}}{12}{figure.caption.14}\protected@file@percent }
\newlabel{fig:pods}{{5}{12}{\textbf {Text specificity controls feature granularity.} On the PODS benchmark, coarse prompts (supercategory) degrade performance relative to DINOv2 by discarding instance-level cues. Class-level prompts improve over the baseline. Fine-grained descriptive prompts surpass even a supervised fine-tuned DINOv2, confirming that detailed text acts as a precise steering mechanism}{figure.caption.14}{}}
\newlabel{fig:pods@cref}{{[figure][5][]5}{[1][10][]12}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Denser captions improve localization.} On the Ref4 benchmark, referential segmentation performance increases with caption length, confirming that richer text conditioning yields more precise spatial steering.}}{12}{figure.caption.16}\protected@file@percent }
\newlabel{fig:ref4_token_len}{{6}{12}{\textbf {Denser captions improve localization.} On the Ref4 benchmark, referential segmentation performance increases with caption length, confirming that richer text conditioning yields more precise spatial steering}{figure.caption.16}{}}
\newlabel{fig:ref4_token_len@cref}{{[figure][6][]6}{[1][11][]12}{}{}{}}
