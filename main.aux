\newlabel{fig:tsne_semantic}{{7}{13}{\textbf {Hierarchical semantic steering.} \textbf {Left:} DINOv2 clusters images by object identity (separate clusters for dogs, cats, birds). \textbf {Right:} Conditioned on \texttt {``Animal''}, our method merges all animal classes into a single macro-cluster while preserving within-cluster object-level semantics (dogs closer to cats than to birds)}{figure.caption.20}{}}
\newlabel{fig:tsne_semantic@cref}{{[figure][7][]7}{[1][13][]13}{}{}{}}
